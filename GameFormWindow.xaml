<Window x:Class="KatalogGierKomp.GameFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Game"
        Height="650"
        Width="740"
        MinHeight="650"
        MinWidth="740"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2F6F4E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#24583E" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="30">
        <TextBlock x:Name="HeaderText"
                   Text="Add a game"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,24" />

        <TextBlock Text="Title" FontSize="14" />
        <TextBox x:Name="TitleBox"
                 Height="34"
                 FontSize="14"
                 Margin="0,0,0,18" />

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Score (optional, 0-10)" FontSize="14" />
                <TextBox x:Name="ScoreBox"
                         Height="34"
                         FontSize="14" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Status" FontSize="14" />
                <ComboBox x:Name="CompletionBox"
                          Height="34"
                          FontSize="14"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Plan to play" />
                    <ComboBoxItem Content="Playing" />
                    <ComboBoxItem Content="Completed" />
                    <ComboBoxItem Content="Dropped" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <TextBlock Text="Review" FontSize="14" />
        <TextBox x:Name="ReviewBox"
                 Height="180"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontSize="14"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,18" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
            <Button Content="Choose PNG"
                    Width="140"
                    Click="ChooseImageButton_Click" />
            <TextBlock x:Name="ImageFileText"
                       Text="No PNG selected"
                       FontSize="14"
                       Margin="12,8,0,0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Width="105"
                    Margin="0,0,12,0"
                    Click="SaveButton_Click" />
            <Button Content="Cancel"
                    Width="105"
                    Click="CancelButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>
