<Window x:Class="KatalogGierKomp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KatalogGierKomp"
        mc:Ignorable="d"
        Title="Katalog gier komputerowych"
        Height="520"
        Width="860"
        MinHeight="420"
        MinWidth="720"
        Background="#F4F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#637083" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#253041"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Games Catalog"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="List of titles saved in the local SQLite database"
                               Foreground="#D8DEE8"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#35445A"
                        BorderBrush="#59677A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="GameCountText"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="0 gier" />
                </Border>
            </Grid>
        </Border>

        <Grid Margin="24">
            <TextBlock x:Name="EmptyMessage"
                       Text="No games found in the database."
                       Foreground="#637083"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Visibility="Collapsed" />

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="GamesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:Game}">
                            <Border Background="White"
                                    BorderBrush="#D7DDE5"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="96"
                                            Height="96"
                                            Background="#E6EAF0"
                                            BorderBrush="#C7CFDA"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <TextBlock Text="OKLADKA"
                                                       Foreground="#637083"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <Image Source="{Binding Image}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#18202B" />

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,8,0,0">
                                            <TextBlock Text="Ocena: "
                                                       Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding Score}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#18202B" />
                                            <TextBlock Text="/10"
                                                       Foreground="#637083" />
                                        </StackPanel>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Ukonczenie:"
                                                       Style="{StaticResource MutedText}"
                                                       VerticalAlignment="Center" />
                                            <ProgressBar Grid.Column="2"
                                                         Height="10"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding Completion}"
                                                         VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Completion, StringFormat={}{0}%}"
                                                       Style="{StaticResource MutedText}"
                                                       VerticalAlignment="Center" />
                                        </Grid>

                                        <TextBlock Text="{Binding Review}"
                                                   Foreground="#364154"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
