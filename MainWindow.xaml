<Window x:Class="KatalogGierKomp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KatalogGierKomp"
        mc:Ignorable="d"
        Title="Computer Games Catalog"
        Height="620"
        Width="940"
        MinHeight="520"
        MinWidth="780"
        Background="#F4F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <local:ImageBytesConverter x:Key="ImageBytesConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#637083" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#253041"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Games Catalog"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Titles saved in the local SQLite database"
                               Foreground="#D8DEE8"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="ShowAddFormButton"
                            Content="Add Game"
                            Margin="0,0,12,0"
                            Click="ShowAddFormButton_Click" />

                    <Border Background="#35445A"
                            BorderBrush="#59677A"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                        <TextBlock x:Name="GameCountText"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="0 games" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="AddGamePanel"
                    Background="White"
                    BorderBrush="#D7DDE5"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0,0,0,18"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Add a game"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#18202B" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Title" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="TitleBox" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Score" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="ScoreBox" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Status" Style="{StaticResource MutedText}" />
                            <ComboBox x:Name="CompletionBox"
                                      SelectedIndex="0"
                                      Margin="0,4,0,0">
                                <ComboBoxItem Content="Plan to play" Tag="0" />
                                <ComboBoxItem Content="Playing" Tag="1" />
                                <ComboBoxItem Content="Completed" Tag="2" />
                                <ComboBoxItem Content="Dropped" Tag="3" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="PNG cover" Style="{StaticResource MutedText}" />
                            <Button x:Name="ChooseImageButton"
                                    Content="Choose PNG"
                                    Margin="0,4,0,0"
                                    Click="ChooseImageButton_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Review" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="ReviewBox"
                                     AcceptsReturn="True"
                                     Height="70"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,4,0,0" />
                            <TextBlock x:Name="ImageFileText"
                                       Text="No PNG selected"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="Save"
                                VerticalAlignment="Bottom"
                                Click="SaveGameButton_Click" />
                        <Button Grid.Column="4"
                                Content="Cancel"
                                VerticalAlignment="Bottom"
                                Click="CancelAddButton_Click" />
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <TextBlock x:Name="EmptyMessage"
                           Text="No games found in the database."
                           Foreground="#637083"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="Collapsed" />

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="GamesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:Game}">
                                <Border Background="White"
                                        BorderBrush="#D7DDE5"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="14"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="96"
                                                Height="96"
                                                Background="#E6EAF0"
                                                BorderBrush="#C7CFDA"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <TextBlock Text="COVER"
                                                           Foreground="#637083"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <Image Source="{Binding Image, Converter={StaticResource ImageBytesConverter}}"
                                                       Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="#18202B" />

                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,8,0,0">
                                                <TextBlock Text="Score: "
                                                           Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding Score}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#18202B" />
                                                <TextBlock Text="/10"
                                                           Foreground="#637083" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,8,0,0">
                                                <TextBlock Text="Status: "
                                                           Style="{StaticResource MutedText}" />
                                                <TextBlock Text="{Binding CompletionStatus}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#18202B" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding Review}"
                                                       Foreground="#364154"
                                                       Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
