<Window x:Class="KatalogGierKomp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KatalogGierKomp"
        Title="Computer Games Catalog"
        Height="760"
        Width="1200"
        MinHeight="650"
        MinWidth="1000"
        Background="#EEF3F8">
    <Window.Resources>
        <local:ImageBytesConverter x:Key="ImageBytesConverter" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2F6F4E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#24583E" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2F4858" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Computer Games Catalog"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock x:Name="GameCountText"
                               Text="0 games"
                               Foreground="White"
                               Margin="0,8,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button Content="Add Game"
                            Width="120"
                            HorizontalAlignment="Right"
                            Click="AddGameButton_Click" />

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Filter:" Foreground="White" Margin="0,6,5,0" />
                        <ComboBox x:Name="FilterBox"
                                  Width="150"
                                  Height="32"
                                  SelectedIndex="0"
                                  SelectionChanged="FilterOrSortChanged">
                            <ComboBoxItem Content="All" />
                            <ComboBoxItem Content="Plan to play" />
                            <ComboBoxItem Content="Playing" />
                            <ComboBoxItem Content="Completed" />
                            <ComboBoxItem Content="Dropped" />
                        </ComboBox>

                        <TextBlock Text="Sort:" Foreground="White" Margin="20,6,5,0" />
                        <ComboBox x:Name="SortBox"
                                  Width="160"
                                  Height="32"
                                  SelectedIndex="0"
                                  SelectionChanged="FilterOrSortChanged">
                            <ComboBoxItem Content="Newest first" />
                            <ComboBoxItem Content="Name A-Z" />
                            <ComboBoxItem Content="Name Z-A" />
                            <ComboBoxItem Content="Score high-low" />
                            <ComboBoxItem Content="Score low-high" />
                            <ComboBoxItem Content="Status" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="10">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="GamesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="230"
                                    Background="White"
                                    BorderBrush="#B7C6D6"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="8">
                                <StackPanel>
                                    <Border Width="190"
                                            Height="270"
                                            Background="#DCE7F2"
                                            BorderBrush="#B7C6D6"
                                            BorderThickness="1"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,10">
                                        <Grid ClipToBounds="True">
                                            <TextBlock Text="Cover"
                                                       Foreground="#2F4858"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <Image Source="{Binding Image, Converter={StaticResource ImageBytesConverter}}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="{Binding Title}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               Foreground="#1D2D35" />

                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,8">
                                        <TextBlock Text="Score: " FontWeight="Bold" />
                                        <TextBlock Text="{Binding ScoreText}" />
                                        <TextBlock Text=" | " />
                                        <TextBlock Text="Status: " FontWeight="Bold" />
                                        <TextBlock Text="{Binding CompletionStatus}" Foreground="#2F6F4E" FontWeight="Bold" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="View"
                                                Width="58"
                                                Margin="0,0,6,0"
                                                CommandParameter="{Binding}"
                                                Click="ViewGameButton_Click" />
                                        <Button Content="Edit"
                                                Width="58"
                                                Margin="0,0,6,0"
                                                CommandParameter="{Binding}"
                                                Click="EditGameButton_Click" />
                                        <Button Content="Delete"
                                                Width="64"
                                                CommandParameter="{Binding}"
                                                Click="DeleteGameButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="EmptyMessage"
                       Text="No games found in the database."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>
    </DockPanel>
</Window>
