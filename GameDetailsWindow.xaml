<Window x:Class="KatalogGierKomp.GameDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KatalogGierKomp"
        Title="Game Details"
        Height="560"
        Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#EEF3F8">
    <Window.Resources>
        <local:ImageBytesConverter x:Key="ImageBytesConverter" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2F6F4E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#24583E" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Window.Resources>

    <Border Margin="20"
            Padding="18"
            Background="White"
            BorderBrush="#B7C6D6"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border Width="280"
                    Height="400"
                    Background="#DCE7F2"
                    BorderBrush="#B7C6D6"
                    BorderThickness="1">
                <Grid ClipToBounds="True">
                    <TextBlock Text="Cover"
                               Foreground="#2F4858"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <Image Source="{Binding Image, Converter={StaticResource ImageBytesConverter}}"
                           Stretch="UniformToFill" />
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{Binding Title}"
                           FontSize="30"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Foreground="#1D2D35" />

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <TextBlock Text="Score: " FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="{Binding ScoreText}" FontSize="18" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Status: " FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="{Binding CompletionStatus}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2F6F4E" />
                </StackPanel>

                <TextBlock Text="Review"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,24,0,6" />
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Height="260">
                    <TextBlock Text="{Binding Review}"
                               FontSize="15"
                               TextWrapping="Wrap" />
                </ScrollViewer>

                <Button Content="Close"
                        Width="100"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0"
                        Click="CloseButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
